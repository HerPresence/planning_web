# ============================================================
# ETL Configuration
# Copy to .env and fill in real values.
# .env is gitignored -- never commit passwords.
# ============================================================

# ------------------------------------------------------------
# WINDOWS SSAS
# Run: etl/windows_ssas/run_etl.bat  (on Windows with SSAS access)
# ------------------------------------------------------------
# Use "localhost" when ETL runs on the same machine as SSAS.
WINDOWS_SSAS_SERVER=localhost
WINDOWS_SSAS_DATABASE=OLAP_Overtrans
# Leave empty to use Windows Integrated Security (SSPI)
WINDOWS_SSAS_LOGIN=
WINDOWS_SSAS_PASSWORD=

# ------------------------------------------------------------
# POWER BI XMLA
# Run: etl/powerbi_xmla/etl_pnl_powerbi.py  (Mac or cloud)
# Requires: Power BI Premium or PPU, XMLA endpoint enabled
# ------------------------------------------------------------
# Format: powerbi://api.powerbi.com/v1.0/myorg/WorkspaceName
POWERBI_XMLA_ENDPOINT=
POWERBI_XMLA_DATASET=
# Service principal credentials (Azure AD app registration)
POWERBI_XMLA_TENANT_ID=
POWERBI_XMLA_CLIENT_ID=
POWERBI_XMLA_CLIENT_SECRET=

# ------------------------------------------------------------
# POSTGRESQL  (used by both runners)
# ------------------------------------------------------------
# Use "localhost" when ETL runs on the same Windows server as PostgreSQL.
# Use IP when ETL runs from Mac/cloud.
PG_HOST=192.168.100.11
PG_PORT=5432
PG_DATABASE=planning_db
PG_USER=postgres
PG_PASSWORD=

# ------------------------------------------------------------
# LEGACY (backward compat with old etl_pnl_olap.py)
# ------------------------------------------------------------
OLAP_SERVER=localhost
OLAP_DATABASE=OLAP_Overtrans
OLAP_LOGIN=
OLAP_PASSWORD=
